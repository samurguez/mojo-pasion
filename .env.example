# ── Stripe ──────────────────────────────────────────────────────────────────
# Obtén estas claves en https://dashboard.stripe.com/apikeys (cuenta Mojo Pasión)
# En desarrollo usa las TEST keys (prefijo sk_test_ / pk_test_)
# En producción usa las LIVE keys (prefijo sk_live_ / pk_live_)

STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXX
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXX

# ── Price IDs de Stripe ───────────────────────────────────────────────────────
# En TEST: copia los price_id del modo Test del dashboard de Stripe
# En LIVE (Vercel producción): usa los price_id del modo Live
# Stripe mantiene IDs separados para test y live — NO son intercambiables

PRICE_ID_MOJO_SUAVE=price_test_XXXXXXXXXXXXXXXXXX
PRICE_ID_MOJO_PICANTE=price_test_XXXXXXXXXXXXXXXXXX

# ── Formspree ────────────────────────────────────────────────────────────────
# ID del formulario de contacto (https://formspree.io). Endpoint: https://formspree.io/f/<ID>
# PUBLIC_ → expuesto al cliente (el form envía vía fetch desde el navegador). No es secreto.
# Replicar también en Vercel → Settings → Environment Variables (Production + Preview).

PUBLIC_FORMSPREE_ID=XXXXXXXX
