---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

import cormorantLatin400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorantLatin400i from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-italic.woff2?url';
import dmSansLatin300 from '@fontsource/dm-sans/files/dm-sans-latin-300-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  schemaJsonLd?: object;
  headerShowCart?: boolean;
  headerShowCta?: boolean;
  headerTransparentOnTop?: boolean;
  footerVariant?: 'full' | 'minimal';
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  canonical,
  noindex = false,
  ogImage = 'https://www.mojopasion.com/images/hero.jpg',
  schemaJsonLd,
  headerShowCart = true,
  headerShowCta = false,
  headerTransparentOnTop = false,
  footerVariant = 'full',
} = Astro.props;

const showOg = Boolean(ogDescription);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href={cormorantLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorantLatin400i} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={dmSansLatin300} as="font" type="font/woff2" crossorigin />
    {noindex && <meta name="robots" content="noindex" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {showOg && (
      <Fragment>
        <meta property="og:type" content="website" />
        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={ogDescription} />
        <meta property="og:image" content={ogImage} />
        {canonical && <meta property="og:url" content={canonical} />}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={ogTitle} />
        <meta name="twitter:description" content={ogDescription} />
        <meta name="twitter:image" content={ogImage} />
      </Fragment>
    )}
    {schemaJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaJsonLd)} />}
    <slot name="head" />
  </head>
  <body>
    <Header
      showCart={headerShowCart}
      showCta={headerShowCta}
      transparentOnTop={headerTransparentOnTop}
    />
    <slot />
    <Footer variant={footerVariant} />
    <CookieConsent />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
