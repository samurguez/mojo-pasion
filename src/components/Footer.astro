---
interface Props {
  variant?: 'full' | 'minimal';
}
const { variant = 'full' } = Astro.props;

const navLinks = [
  { href: '/#productos', label: 'Productos' },
  { href: '/#ingredientes', label: 'Ingredientes' },
  { href: '/tienda', label: 'Tienda' },
  { href: '/#horeca', label: 'Horeca' },
];

const legalLinks = [
  { href: '/aviso-legal', label: 'Aviso legal' },
  { href: '/privacidad', label: 'Privacidad' },
];

const socialLinks = [
  { href: 'https://instagram.com/mojo_pasion', label: 'Instagram' },
  { href: 'https://tiktok.com/@mojopasion', label: 'TikTok' },
];

const SEO_TAGLINE = 'Mojo Pasión — Mojo rojo palmero artesano elaborado en Canarias con pimienta palmera, sal marina de la isla y respetando la receta familiar.';
---

{variant === 'full' ? (
  <footer class="footer footer-full">
    <div class="footer-main">
      <a href="/" class="footer-logo" aria-label="Mojo Pasión - Inicio">
        <img src="/images/logo-horizontal.png" alt="Mojo Pasión" width="160" height="32" />
      </a>
      <div class="footer-groups">
        <nav class="footer-group" aria-label="Navegación">
          <h3 class="footer-group-title">Navegación</h3>
          <ul class="footer-list">
            {navLinks.map(({ href, label }) => (
              <li><a href={href} class="footer-link">{label}</a></li>
            ))}
          </ul>
        </nav>
        <nav class="footer-group" aria-label="Legal">
          <h3 class="footer-group-title">Legal</h3>
          <ul class="footer-list">
            {legalLinks.map(({ href, label }) => (
              <li><a href={href} class="footer-link">{label}</a></li>
            ))}
          </ul>
        </nav>
        <nav class="footer-group" aria-label="Síguenos">
          <h3 class="footer-group-title">Síguenos</h3>
          <ul class="footer-list">
            {socialLinks.map(({ href, label }) => (
              <li><a href={href} target="_blank" rel="noopener noreferrer" class="footer-social-link">{label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">© 2026 Mojo Pasión. Todos los derechos reservados.</p>
      <p class="footer-seo">{SEO_TAGLINE}</p>
    </div>
  </footer>
) : (
  <footer class="footer footer-minimal">
    <p class="footer-copy">© 2026 Mojo Pasión. Todos los derechos reservados.</p>
    <div class="footer-minimal-links">
      {legalLinks.map(({ href, label }) => (
        <a href={href} class="footer-link">{label}</a>
      ))}
      {socialLinks.map(({ href, label }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="footer-social-link">{label}</a>
      ))}
    </div>
  </footer>
)}

<style>
  .footer {
    background: #0a0a0a;
    border-top: 0.5px solid #222;
    color: #aaa;
    font-family: var(--font-sans);
  }

  /* === Variante FULL === */
  .footer-full {
    padding: 3rem 3rem 1.5rem;
  }

  .footer-main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-logo img {
    height: 32px;
    width: auto;
    opacity: 0.85;
    transition: opacity 0.2s ease;
    display: block;
  }

  .footer-logo:hover img {
    opacity: 1;
  }

  .footer-groups {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .footer-group-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin: 0 0 1rem 0;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link,
  .footer-social-link {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.5px;
    color: #aaa;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-crema);
  }

  .footer-social-link:hover {
    color: var(--color-rojo);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 0.5px solid #1a1a1a;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    text-align: center;
  }

  .footer-copy,
  .footer-seo {
    margin: 0;
    font-size: 11px;
    font-weight: 300;
    color: #888;
    line-height: 1.5;
  }

  .footer-seo {
    max-width: 60ch;
  }

  /* === Variante MINIMAL === */
  .footer-minimal {
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-minimal .footer-copy {
    font-size: 11px;
    color: #888;
    margin: 0;
  }

  .footer-minimal-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-minimal .footer-link,
  .footer-minimal .footer-social-link {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .footer-full {
      padding: 2.5rem 1.5rem 1.5rem;
    }

    .footer-main {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 2rem;
    }

    .footer-groups {
      gap: 2.5rem;
      justify-content: center;
    }

    .footer-list {
      align-items: center;
    }

    .footer-minimal {
      flex-direction: column;
      padding: 1.25rem 1.5rem;
      text-align: center;
    }

    .footer-minimal-links {
      justify-content: center;
    }
  }
</style>
