---
interface Props {
  showCart?: boolean;
}
const { showCart = true } = Astro.props;
---

<header class="store-header">
  <a href="/" class="store-header-logo" aria-label="Volver a inicio">
    <img
      src="/images/logo-horizontal.png"
      alt="Mojo Pasión"
      width="160"
      height="40"
    />
  </a>

  {showCart && (
    <a href="/checkout" id="cart-link" class="cart-toggle" aria-label="Ver carrito">
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
        <line x1="3" y1="6" x2="21" y2="6" />
        <path d="M16 10a4 4 0 01-8 0" />
      </svg>
      <span id="cart-count" class="cart-count" aria-label="artículos en el carrito">0</span>
    </a>
  )}
</header>

<!-- window.MojoCart — módulo global disponible en todas las páginas de tienda -->
<script is:inline>
  window.MojoCart = (function () {
    var KEY = 'mojo-cart-v1';

    function read() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch (e) { return []; }
    }

    function write(items) {
      localStorage.setItem(KEY, JSON.stringify(items));
      window.dispatchEvent(new CustomEvent('cart:update', { detail: { items: items } }));
    }

    return {
      get: read,

      add: function (product, qty) {
        if (!qty || qty < 1) qty = 1;
        var items = read();
        var idx = items.findIndex(function (i) { return i.priceId === product.priceId; });
        if (idx >= 0) {
          items[idx].quantity += qty;
        } else {
          items.push({
            priceId: product.priceId,
            name: product.name,
            priceInCents: product.priceInCents,
            priceDisplay: product.priceDisplay,
            quantity: qty,
          });
        }
        write(items);
      },

      setQty: function (priceId, qty) {
        if (qty < 1) { this.remove(priceId); return; }
        var items = read();
        var idx = items.findIndex(function (i) { return i.priceId === priceId; });
        if (idx >= 0) { items[idx].quantity = qty; write(items); }
      },

      remove: function (priceId) {
        write(read().filter(function (i) { return i.priceId !== priceId; }));
      },

      clear: function () { write([]); },

      total: function () {
        return read().reduce(function (s, i) { return s + i.priceInCents * i.quantity; }, 0);
      },

      count: function () {
        return read().reduce(function (s, i) { return s + i.quantity; }, 0);
      },
    };
  })();

  function _updateCartBadge() {
    var badge = document.getElementById('cart-count');
    if (!badge) return;
    var count = window.MojoCart.count();
    badge.textContent = String(count);
    badge.style.display = count > 0 ? 'flex' : 'none';
  }

  document.addEventListener('DOMContentLoaded', _updateCartBadge);
  window.addEventListener('cart:update', _updateCartBadge);
</script>

<style>
  .store-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 2.5rem;
    background: var(--color-negro);
    border-bottom: 0.5px solid #222;
    backdrop-filter: blur(8px);
  }

  .store-header-logo img {
    height: 34px;
    width: auto;
    display: block;
  }

  .cart-toggle {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-crema);
    padding: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    text-decoration: none;
  }

  .cart-toggle:hover {
    color: var(--color-rojo);
  }

  .cart-count {
    position: absolute;
    top: -2px;
    right: -4px;
    background: var(--color-rojo);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .store-header {
      padding: 0.8rem 1.25rem;
    }
  }
</style>
