---
// CartDrawer.astro — carrito (bottom sheet en móvil / drawer lateral en desktop)
// Incluye window.MojoCart (módulo global del carrito) y toda la lógica de UI.
import { SHIPPING_ZONES, PRODUCTS } from '../lib/tienda-config';

const tenerifeThreshold = SHIPPING_ZONES.tenerife.freeFromInCents;
const productPrice = PRODUCTS[0].priceInCents;
---

<!-- Backdrop -->
<div id="cart-overlay" class="cart-overlay" role="presentation"></div>

<!-- Drawer -->
<aside
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Tu carrito"
>
  <div class="cart-handle" aria-hidden="true"></div>

  <div class="cart-head">
    <p class="cart-title">Tu pedido</p>
    <button id="cart-close" class="cart-close" aria-label="Cerrar carrito">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <div id="cart-body" class="cart-body">
    <div id="cart-items-list" class="cart-items-list">
      <p class="cart-empty-msg">Tu carrito está vacío.</p>
    </div>
    <div id="cart-incentivo" class="cart-incentivo" style="display:none"></div>
  </div>

  <div class="cart-foot">
    <div class="cart-subtotal-row">
      <span class="cart-subtotal-label">Subtotal</span>
      <strong id="cart-subtotal-val" class="cart-subtotal-amount">0,00 €</strong>
    </div>
    <a
      id="cart-to-checkout"
      href="/checkout"
      class="cart-cta cart-cta-disabled"
      aria-disabled="true"
    >
      Ver opciones de entrega →
    </a>
  </div>
</aside>

<style is:global>
  /* ── Overlay ── */
  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .cart-overlay.cart-open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Drawer (desktop: lateral derecho) ── */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 400px;
    max-width: 100%;
    height: 100dvh;
    background: #1a1a1a;
    border-left: 0.5px solid #2a2a2a;
    z-index: 201;
    display: flex;
    flex-direction: column;
    transform: translateX(105%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .cart-drawer.cart-open {
    transform: translateX(0);
  }

  .cart-handle {
    display: none;
  }

  /* ── Drawer (móvil: bottom sheet) ── */
  @media (max-width: 767px) {
    .cart-drawer {
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: auto;
      max-height: 85dvh;
      border-left: none;
      border-top: 0.5px solid #2a2a2a;
      border-radius: 16px 16px 0 0;
      transform: translateY(110%);
    }

    .cart-drawer.cart-open {
      transform: translateY(0);
    }

    .cart-handle {
      display: block;
      width: 36px;
      height: 4px;
      background: #333;
      border-radius: 2px;
      margin: 0.85rem auto 0;
      flex-shrink: 0;
    }
  }

  /* ── Interior ── */
  .cart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 0.5px solid #2a2a2a;
    flex-shrink: 0;
  }

  .cart-title {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-crema);
    margin: 0;
  }

  .cart-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .cart-close:hover {
    color: var(--color-crema);
  }

  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
  }

  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cart-empty-msg {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    color: #555;
    text-align: center;
    padding: 2.5rem 0;
  }

  /* Items generados por JS */
  .cart-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 0.5px solid #242424;
  }

  .cart-item:last-child {
    border-bottom: none;
  }

  .cart-item-info {
    flex: 1;
    min-width: 0;
  }

  .cart-item-name {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    color: var(--color-crema);
    display: block;
    margin-bottom: 0.2rem;
  }

  .cart-item-price {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 300;
    color: #888;
  }

  .cart-item-qty-ctrl {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cart-qty-btn {
    background: none;
    border: 0.5px solid #333;
    color: var(--color-crema);
    width: 28px;
    height: 28px;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    font-family: var(--font-sans);
    line-height: 1;
    padding: 0;
  }

  .cart-qty-btn:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .cart-item-qty-val {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-crema);
    min-width: 20px;
    text-align: center;
  }

  /* Incentivo */
  .cart-incentivo {
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    background: rgba(232, 0, 45, 0.07);
    border: 0.5px solid rgba(232, 0, 45, 0.25);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.6;
    letter-spacing: 0.3px;
  }

  /* Footer del drawer */
  .cart-foot {
    padding: 1.25rem 1.5rem;
    border-top: 0.5px solid #2a2a2a;
    flex-shrink: 0;
  }

  .cart-subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .cart-subtotal-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #888;
  }

  .cart-subtotal-amount {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--color-crema);
  }

  .cart-cta {
    display: block;
    width: 100%;
    padding: 1rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    background: var(--color-rojo);
    color: #fff;
    transition: opacity 0.2s;
  }

  .cart-cta:hover:not(.cart-cta-disabled) {
    opacity: 0.85;
  }

  .cart-cta-disabled {
    opacity: 0.3;
    pointer-events: none;
    cursor: default;
  }
</style>

<script define:vars={{ tenerifeThreshold, productPrice }} is:inline>
  // ── window.MojoCart — módulo global del carrito ──────────────────────────
  window.MojoCart = (() => {
    const KEY = 'mojo-cart-v1';

    const read = () => {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch { return []; }
    };

    const write = (items) => {
      localStorage.setItem(KEY, JSON.stringify(items));
      window.dispatchEvent(new CustomEvent('cart:update', { detail: { items } }));
    };

    return {
      get: read,

      add(product, qty) {
        if (!qty || qty < 1) qty = 1;
        const items = read();
        const idx = items.findIndex(i => i.priceId === product.priceId);
        if (idx >= 0) {
          items[idx].quantity += qty;
        } else {
          items.push({
            priceId: product.priceId,
            name: product.name,
            priceInCents: product.priceInCents,
            priceDisplay: product.priceDisplay,
            quantity: qty,
          });
        }
        write(items);
      },

      setQty(priceId, qty) {
        if (qty < 1) { window.MojoCart.remove(priceId); return; }
        const items = read();
        const item = items.find(i => i.priceId === priceId);
        if (item) { item.quantity = qty; write(items); }
      },

      remove(priceId) {
        write(read().filter(i => i.priceId !== priceId));
      },

      clear() { write([]); },

      total() {
        return read().reduce((s, i) => s + i.priceInCents * i.quantity, 0);
      },

      count() {
        return read().reduce((s, i) => s + i.quantity, 0);
      },
    };
  })();

  // ── Helpers de formato ──────────────────────────────────────────────────
  function fmtEur(cents) {
    return (cents / 100).toFixed(2).replace('.', ',') + ' €';
  }

  // ── Actualiza toda la UI del carrito ────────────────────────────────────
  function renderCart() {
    const items = window.MojoCart.get();
    const total = window.MojoCart.total();
    const count = window.MojoCart.count();

    // Badge en la cabecera
    const badge = document.getElementById('cart-count');
    if (badge) {
      badge.textContent = String(count);
      badge.style.display = count > 0 ? 'flex' : 'none';
    }

    // Lista de items
    const listEl = document.getElementById('cart-items-list');
    if (listEl) {
      if (items.length === 0) {
        listEl.innerHTML = '<p class="cart-empty-msg">Tu carrito está vacío.</p>';
      } else {
        listEl.innerHTML = items.map(item => `
          <div class="cart-item">
            <div class="cart-item-info">
              <span class="cart-item-name">${item.name}</span>
              <span class="cart-item-price">${fmtEur(item.priceInCents * item.quantity)}</span>
            </div>
            <div class="cart-item-qty-ctrl">
              <button class="cart-qty-btn" onclick="window.MojoCart.setQty('${item.priceId}', ${item.quantity - 1})" aria-label="Quitar uno">&#x2212;</button>
              <span class="cart-item-qty-val">${item.quantity}</span>
              <button class="cart-qty-btn" onclick="window.MojoCart.setQty('${item.priceId}', ${item.quantity + 1})" aria-label="Añadir uno">+</button>
            </div>
          </div>
        `).join('');
      }
    }

    // Subtotal
    const subtotalEl = document.getElementById('cart-subtotal-val');
    if (subtotalEl) subtotalEl.textContent = fmtEur(total);

    // Estado del botón CTA
    const cta = document.getElementById('cart-to-checkout');
    if (cta) {
      if (count > 0) {
        cta.classList.remove('cart-cta-disabled');
        cta.removeAttribute('aria-disabled');
      } else {
        cta.classList.add('cart-cta-disabled');
        cta.setAttribute('aria-disabled', 'true');
      }
    }

    // Incentivo de envío (basado en umbral de Tenerife)
    const incEl = document.getElementById('cart-incentivo');
    if (incEl) {
      if (total > 0 && total < tenerifeThreshold) {
        const needed = tenerifeThreshold - total;
        const tarros = Math.ceil(needed / productPrice);
        incEl.textContent = `¡Oportunidad! Añade ${tarros} tarro${tarros > 1 ? 's' : ''} más y el envío en Tenerife te sale gratis.`;
        incEl.style.display = 'block';
      } else {
        incEl.style.display = 'none';
      }
    }
  }

  // ── Abrir / cerrar carrito ───────────────────────────────────────────────
  window.openCart = function() {
    document.getElementById('cart-overlay')?.classList.add('cart-open');
    document.getElementById('cart-drawer')?.classList.add('cart-open');
    document.body.style.overflow = 'hidden';
  };

  window.closeCart = function() {
    document.getElementById('cart-overlay')?.classList.remove('cart-open');
    document.getElementById('cart-drawer')?.classList.remove('cart-open');
    document.body.style.overflow = '';
  };

  // ── Inicialización ───────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    renderCart();

    document.getElementById('cart-toggle')?.addEventListener('click', window.openCart);
    document.getElementById('cart-close')?.addEventListener('click', window.closeCart);
    document.getElementById('cart-overlay')?.addEventListener('click', window.closeCart);

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') window.closeCart();
    });
  });

  window.addEventListener('cart:update', renderCart);
</script>
