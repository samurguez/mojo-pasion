---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  priceId: string;
  name: string;
  description: string;
  priceDisplay: string;
  priceInCents: number;
  image: ImageMetadata;
  imageAlt: string;
}

const { priceId, name, description, priceDisplay, priceInCents, image, imageAlt } = Astro.props;
---

<article class="product-card" data-price-id={priceId}>
  <div class="product-img-wrap">
    <Image
      src={image}
      alt={imageAlt}
      class="product-img"
      loading="eager"
      widths={[400, 800, 1200]}
      sizes="(max-width: 767px) 100vw, 50vw"
    />
  </div>

  <div class="product-body">
    <h2 class="product-name">{name}</h2>
    <p class="product-desc">{description}</p>

    <div class="product-bottom">
      <button
        class="product-add-btn"
        data-price-id={priceId}
        data-name={name}
        data-price-in-cents={String(priceInCents)}
        data-price-display={priceDisplay}
        type="button"
        aria-label={`Añadir ${name} al carrito, ${priceDisplay}`}
      >
        Añadir · {priceDisplay}
      </button>
    </div>
  </div>
</article>

<script>
  import { add } from '../lib/cart.ts';

  let redirected = false;

  document.addEventListener('click', (e: Event) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.product-add-btn');
    if (!btn) return;

    const { priceId, priceInCents: priceInCentsStr, priceDisplay } = btn.dataset;
    const productName = btn.dataset.name ?? '';
    if (!priceId || !priceInCentsStr || !priceDisplay) return;
    const priceInCents = Number(priceInCentsStr);

    if (redirected) return;
    redirected = true;

    add({ priceId, name: productName, priceInCents, priceDisplay });

    const value = priceInCents / 100;
    const w = window as unknown as Record<string, unknown>;

    let redirected = false;
    const doRedirect = () => {
      if (redirected) return;
      redirected = true;
      window.location.href = '/checkout';
    };

    if (w['_gaLoaded'] === true) {
      if (w['_pixelLoaded'] === true) {
        (w['fbq'] as (...a: unknown[]) => void)('track', 'AddToCart', {
          content_ids: [priceId], content_name: productName, currency: 'EUR', value,
        });
      }
      (w['gtag'] as (...a: unknown[]) => void)('event', 'add_to_cart', {
        currency: 'EUR', value,
        items: [{ item_id: priceId, item_name: productName, price: value, quantity: 1 }],
        event_callback: doRedirect,
        event_timeout: 2000,
      });
    } else {
      if (w['_pixelLoaded'] === true) {
        (w['fbq'] as (...a: unknown[]) => void)('track', 'AddToCart', {
          content_ids: [priceId], content_name: productName, currency: 'EUR', value,
        });
      }
      doRedirect();
    }
  });

  window.addEventListener('pageshow', (e: PageTransitionEvent) => {
    if (e.persisted) {
      redirected = false;
    }
  });
</script>

<style>
  .product-card {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    background: #1c1c1c;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    overflow: hidden;
  }

  .product-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #0d0d0d;
  }

  .product-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-img {
    transform: scale(1.03);
  }

  .product-body {
    padding: 1.1rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .product-name {
    font-family: var(--font-serif);
    font-size: clamp(34px, 4vw, 52px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-crema);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .product-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    color: #666;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .product-bottom {
    margin-top: auto;
  }

  .product-add-btn {
    display: block;
    width: 100%;
    padding: 1rem 2rem;
    background: #E8002D;
    border: none;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
    text-align: center;
  }

  .product-add-btn:hover {
    background: #c40026;
  }

  @media (min-width: 768px) {
    .product-body {
      padding: 2rem 2.25rem 2.25rem;
    }
  }

  @media (max-width: 767px) {
    .product-body {
      padding: 1.25rem 1.25rem 1.75rem;
    }
  }
</style>
