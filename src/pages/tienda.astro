---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { PRODUCTS } from '../lib/tienda-config';
---

<Layout
  title="Tienda — Mojo Pasión"
  description="Mojo rojo palmero artesano de Canarias. Suave o picante, hecho a mano con pimienta de Puntagorda y sal de Fuencaliente. Envío a Canarias."
  canonical="https://www.mojopasion.com/tienda"
>
  <main class="tienda-main">
    <div class="tienda-intro">
      <p class="tienda-label">Tienda</p>
    </div>

    <div class="tienda-grid">
      {PRODUCTS.map((product) => (
        <ProductCard
          priceId={product.priceId}
          name={product.name}
          description={product.description}
          priceDisplay={product.priceDisplay}
          priceInCents={product.priceInCents}
          image={product.image}
          imageAlt={product.imageAlt}
        />
      ))}
    </div>
  </main>
</Layout>

<style>
  .tienda-main {
    padding-top: 80px;
    min-height: 100vh;
    background: var(--color-negro);
  }

  .tienda-intro {
    padding: 2rem 2.5rem 0.75rem;
    max-width: 1160px;
    margin: 0 auto;
  }

  .tienda-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 0.75rem;
  }

  .tienda-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 1160px;
    margin: 0 auto;
    padding: 0.75rem 1.25rem 4rem;
  }

  @media (min-width: 768px) {
    .tienda-intro {
      padding: 2.5rem 3rem 0.75rem;
    }

    .tienda-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
      padding: 0.75rem 2.5rem 5rem;
    }
  }

  @media (max-width: 767px) {
    .tienda-intro {
      padding: 1.5rem 1.5rem 0.5rem;
    }
  }
</style>
