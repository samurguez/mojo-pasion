---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { PRODUCTS } from '../lib/tienda-config';
import { BUSINESS } from '../data/business';
import { getImage } from 'astro:assets';

const BASE = 'https://www.mojopasion.com';

const productImages = await Promise.all(
  PRODUCTS.map(p => getImage({ src: p.image, width: 800 }))
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Mojo Pasión',
      url: BASE,
      logo: `${BASE}/images/logo-horizontal.png`,
      email: 'hola@mojopasion.com',
      sameAs: [
        'https://www.instagram.com/mojo_pasion',
        'https://www.tiktok.com/@mojopasion',
      ],
    },
    {
      '@type': 'ItemList',
      name: 'Productos Mojo Pasión',
      itemListElement: PRODUCTS.map((product, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'Product',
          name: product.name,
          description: product.description,
          image: `${BASE}${productImages[i].src}`,
          brand: { '@type': 'Brand', name: 'Mojo Pasión' },
          offers: {
            '@type': 'Offer',
            price: (product.priceInCents / 100).toFixed(2),
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
            url: `${BASE}/tienda`,
            shippingDetails: [
              {
                '@type': 'OfferShippingDetails',
                shippingRate: { '@type': 'MonetaryAmount', value: (BUSINESS.shipping.zones.tenerife.costCents / 100).toFixed(2), currency: 'EUR' },
                shippingDestination: {
                  '@type': 'DefinedRegion',
                  addressCountry: BUSINESS.address.countryCode,
                  addressRegion: BUSINESS.address.province,
                  postalCodePrefix: BUSINESS.shipping.zones.tenerife.postalCodePrefix,
                },
                deliveryTime: {
                  '@type': 'ShippingDeliveryTime',
                  handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 2, unitCode: 'DAY' },
                  transitTime: { '@type': 'QuantitativeValue', minValue: BUSINESS.shipping.zones.tenerife.deliveryDaysMin, maxValue: BUSINESS.shipping.zones.tenerife.deliveryDaysMax, unitCode: 'DAY' },
                },
              },
              {
                '@type': 'OfferShippingDetails',
                shippingRate: { '@type': 'MonetaryAmount', value: (BUSINESS.shipping.zones.canarias.costCents / 100).toFixed(2), currency: 'EUR' },
                shippingDestination: {
                  '@type': 'DefinedRegion',
                  addressCountry: BUSINESS.address.countryCode,
                  addressRegion: 'Las Palmas',
                  postalCodePrefix: BUSINESS.shipping.zones.canarias.postalCodePrefix,
                },
                deliveryTime: {
                  '@type': 'ShippingDeliveryTime',
                  handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 2, unitCode: 'DAY' },
                  transitTime: { '@type': 'QuantitativeValue', minValue: BUSINESS.shipping.zones.canarias.deliveryDaysMin, maxValue: BUSINESS.shipping.zones.canarias.deliveryDaysMax, unitCode: 'DAY' },
                },
              },
            ],
            hasMerchantReturnPolicy: {
              '@type': 'MerchantReturnPolicy',
              applicableCountry: BUSINESS.address.countryCode,
              returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
              merchantReturnDays: BUSINESS.returns.days,
              returnMethod: 'https://schema.org/ReturnByMail',
              returnFees: 'https://schema.org/ReturnShippingFees',
              merchantReturnLink: `${BASE}/devoluciones`,
            },
          },
        },
      })),
    },
  ],
};
---

<Layout
  title="Mojo Pasión — Mojo rojo palmero artesano"
  description="No es para todos. Es para ti. Mojo rojo palmero artesano con pimienta de Puntagorda, sal de Fuencaliente y receta de familia. Hecho a mano en Canarias."
  ogTitle="Mojo Pasión — No es para todos. Es para ti."
  ogDescription="Mojo rojo palmero artesano con pimienta de Puntagorda, sal de Fuencaliente y receta de familia. Hecho a mano en Canarias."
  canonical="https://www.mojopasion.com"
  headerShowCta
  headerTransparentOnTop
  schemaJsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero">
    <img src="/images/hero.avif" alt="Tarro de mojo rojo palmero artesano sobre madera — Mojo Pasión canario" class="hero-img" />
    <div class="hero-content">
      <h1 class="hero-small">Mojo rojo palmero artesano</h1>
      <p class="hero-title">No es para todos</p>
      <p class="hero-subtitle">Es para ti.</p>
      <a href="/tienda" class="hero-cta">Comprar</a>
    </div>
  </section>

  <!-- PIMIENTA PALMERA -->
  <section class="ingrediente fade-in">
    <img src="/images/pimienta.avif" alt="Pimienta palmera de Puntagorda — ingrediente artesano del mojo rojo canario" class="ingrediente-img" style="object-position: center 65%;" />
    <div class="ingrediente-content derecha">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">Pimienta palmera, punto.</h2>
          <p class="ingrediente-sub">Hay muchos mojos, este es auténtico mojo rojo palmero.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SAL DE FUENCALIENTE -->
  <section class="ingrediente">
    <img src="/images/sal.avif" alt="Sal marina de Fuencaliente — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" />
    <div class="ingrediente-content izquierda">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">Sal marina de Fuencaliente.</h2>
          <p class="ingrediente-sub">El ingrediente que nadie nombra su origen, y a nosotros nos enorgullece.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ACEITE DE OLIVA -->
  <section class="ingrediente">
    <img src="/images/aceite.avif" alt="Aceite de oliva virgen extra — base del mojo rojo palmero artesano canario" class="ingrediente-img" />
    <div class="ingrediente-content derecha">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">Aceite de oliva, sin debate.</h2>
          <p class="ingrediente-sub">Acompañado con el toque justo de vinagre de vino.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AJO DEL PAÍS -->
  <section class="ingrediente">
    <img src="/images/ajo.avif" alt="Ajo del país canario — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" style="object-position: center bottom;" />
    <div class="ingrediente-content izquierda">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">Ajo del país, el que sabe.</h2>
          <p class="ingrediente-sub">Pequeño, imperfecto, insustituible.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMINO -->
  <section class="ingrediente">
    <img src="/images/comino.avif" alt="Comino en grano — especia artesana del mojo rojo palmero canario" class="ingrediente-img" style="object-position: 20% center;" />
    <div class="ingrediente-content derecha">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">Comino, el que no se ve pero se siente.</h2>
          <p class="ingrediente-sub">Discreto. Imprescindible. El grano que le da el toque.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LAS MANOS -->
  <section class="ingrediente">
    <img src="/images/manos.avif" alt="Manos artesanas elaborando mojo rojo palmero canario — receta tradicional" class="ingrediente-img" />
    <div class="ingrediente-content izquierda">
      <div class="ingrediente-texto">
        <div class="ingrediente-barra"></div>
        <div class="ingrediente-copy">
          <h2 class="ingrediente-title">El ingrediente estrella, el que no se puede comprar.</h2>
          <p class="ingrediente-sub">Las manos de quien lleva décadas haciendo el mojo rojo palmero. Mojo Pasión.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTOS -->
  <section class="productos fade-in" id="productos">
    <div class="productos-grid">
      {PRODUCTS.map((product) => (
        <ProductCard
          priceId={product.priceId}
          name={product.name}
          description={product.description}
          priceDisplay={product.priceDisplay}
          priceInCents={product.priceInCents}
          image={product.image}
          imageAlt={product.imageAlt}
        />
      ))}
    </div>
  </section>

  <!-- CTA PAPA -->
  <section class="cta-papa fade-in">
    <img src="/images/papa.avif" alt="Papa arrugada canaria con mojo rojo palmero artesano — Mojo Pasión" class="cta-papa-img" />
    <div class="cta-papa-content">
      <p class="hero-title">¿Tienes un <span style="color: var(--color-rojo);">negocio?</span></p>
      <p class="papa-subtitle">Formatos HORECA para llevar el mojo palmero artesano a tu carta.</p>
      <a href="mailto:hola@mojopasion.com" class="hero-cta">Escríbenos</a>
    </div>
  </section>

  <script>
    import '../lib/cart.ts';
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    });
  </script>
</Layout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 560px;
  }

  .hero-small {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(48px, 6.2vw, 86px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-rojo);
    line-height: 1.05;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    background: rgba(17, 17, 17, 0.85);
    border: 0.5px solid #444444;
    padding: 0.75rem 2rem;
    transition: border-color 0.3s ease;
  }

  .hero-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .ingrediente {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ingrediente-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ingrediente-content {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(17, 17, 17, 0.85);
    max-width: 560px;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .ingrediente-content:hover {
    transform: translateY(-50%) scale(1.02);
    background: rgba(17, 17, 17, 0.92);
  }

  .ingrediente-content.izquierda {
    left: 0;
  }

  .ingrediente-content.derecha {
    right: 0;
  }

  .ingrediente-texto {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    padding: 2rem 2rem;
  }

  .ingrediente-copy {
    flex: 1;
    padding: 0 1.5rem;
  }

  .ingrediente-barra {
    width: 3px;
    background: var(--color-rojo);
    flex-shrink: 0;
    align-self: stretch;
    min-height: 80px;
  }

  .ingrediente-title {
    font-family: var(--font-serif);
    font-size: clamp(38px, 3.2vw, 58px);
    font-weight: 400;
    font-style: italic;
    color: #F0EBE0;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ingrediente-sub {
    font-family: var(--font-sans);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    color: #AAAAAA;
    line-height: 1.7;
    letter-spacing: 1.2px;
  }

  .productos {
    background: #111111;
    padding: 6rem 2rem;
  }

  .productos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
    max-width: 1160px;
    margin: 0 auto;
  }

  .cta-papa {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .cta-papa-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 85% center;
  }

  .cta-papa-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 600px;
  }

  .papa-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero-content {
      left: 5%;
      right: 5%;
      max-width: 90%;
      top: 5%;
      transform: none;
    }

    .hero-title {
      font-size: clamp(42px, 12vw, 64px);
    }

    .hero-subtitle {
      font-size: clamp(42px, 12vw, 64px);
    }

    .ingrediente-content {
      max-width: 90%;
    }

    .ingrediente-content.izquierda {
      left: 0;
    }

    .ingrediente-content.derecha {
      right: 0;
    }

    .ingrediente-title {
      font-size: clamp(28px, 8vw, 44px);
    }

    .ingrediente-sub {
      font-size: 12px;
    }

    .productos {
      padding: 4rem 1.25rem;
    }

    .productos-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .cta-papa-content {
      left: 5%;
      right: 5%;
      max-width: 90%;
      top: 5%;
      transform: none;
    }

    .papa-subtitle {
      font-size: clamp(20px, 5vw, 28px);
      margin-top: 1rem;
    }
  }
</style>
