---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mojo Pasión — Mojo rojo palmero artesano</title>
  </head>
  <body>
    <main>

      <!-- HERO -->
      <section class="hero">
        <img src="/images/hero.jpg" alt="Mojo Pasión" class="hero-img" />
        <div class="hero-content">
          <p class="hero-small">Mojo rojo palmero artesano</p>
          <h1 class="hero-title">El mojo que no se vende.</h1>
          <p class="hero-subtitle">Hasta ahora.</p>
        </div>
      </section>

      <!-- PIMIENTA PALMERA -->
      <section class="ingrediente">
        <img src="/images/pimienta.jpg" alt="Pimienta palmera de Puntagorda" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">La pimienta palmera lo cambia todo.</h2>
            <p class="ingrediente-sub">La que las abuelas guardaban para el mojo de casa.</p>
          </div>
        </div>
      </section>

      <!-- SAL DE FUENCALIENTE -->
      <section class="ingrediente">
        <img src="/images/sal.jpg" alt="Sal marina de Fuencaliente" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">El ingrediente que nadie nombra.</h2>
            <p class="ingrediente-sub">Sal marina de Fuencaliente, La Palma.</p>
          </div>
        </div>
      </section>

      <!-- ACEITE DE OLIVA -->
      <section class="ingrediente">
        <img src="/images/aceite.jpg" alt="Aceite de oliva" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">Hay debate en el aceite.</h2>
            <p class="ingrediente-sub">El nuestro es de oliva.</p>
          </div>
        </div>
      </section>

      <!-- AJO DEL PAÍS -->
      <section class="ingrediente">
        <img src="/images/ajo.jpg" alt="Ajo del país" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">Pequeño. Imperfecto. Insustituible.</h2>
            <p class="ingrediente-sub">Ajo del país. El que sabe de verdad.</p>
          </div>
        </div>
      </section>

      <!-- COMINO -->
      <section class="ingrediente">
        <img src="/images/comino.jpg" alt="Comino" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">Discreto. Imprescindible.</h2>
            <p class="ingrediente-sub">El comino lo redondea todo.</p>
          </div>
        </div>
      </section>

      <!-- LAS MANOS -->
      <section class="ingrediente">
        <img src="/images/manos.jpg" alt="Las manos de quien lo hace" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-barra"></div>
          <div>
            <h2 class="ingrediente-title">Hay un ingrediente que no se puede comprar.</h2>
            <p class="ingrediente-sub">Las manos de quien lleva cincuenta años haciéndolo.</p>
          </div>
        </div>
      </section>

    </main>
  </body>
</html>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 560px;
  }

  .hero-small {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-rojo);
    line-height: 1.05;
  }

  .ingrediente {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ingrediente-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ingrediente-content {
    position: absolute;
    top: 0;
    height: 100%;
    width: 30%;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 2.5rem;
    background: rgba(17, 17, 17, 0.72);
  }

  .ingrediente-content.izquierda {
    left: 0;
  }

  .ingrediente-content.derecha {
    right: 0;
  }

  .ingrediente-barra {
    width: 3px;
    min-height: 160px;
    background: var(--color-rojo);
    flex-shrink: 0;
    border-radius: 2px;
    margin-top: 6px;
  }

  .ingrediente-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-crema);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ingrediente-sub {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    color: var(--color-gris);
    line-height: 1.7;
    letter-spacing: 0.5px;
  }
</style>