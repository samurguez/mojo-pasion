---
import '../styles/global.css';
import ProductCard from '../components/ProductCard.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { PRODUCTS } from '../lib/tienda-config';
import { getImage } from 'astro:assets';

import cormorantLatin400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorantLatin400i from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-italic.woff2?url';
import dmSansLatin300 from '@fontsource/dm-sans/files/dm-sans-latin-300-normal.woff2?url';

const BASE = 'https://www.mojopasion.com';

const productImages = await Promise.all(
  PRODUCTS.map(p => getImage({ src: p.image, width: 800 }))
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Mojo Pasión',
      url: BASE,
      logo: `${BASE}/images/logo-horizontal.png`,
      email: 'hola@mojopasion.com',
      sameAs: [
        'https://www.instagram.com/mojo_pasion',
        'https://www.tiktok.com/@mojopasion',
      ],
    },
    {
      '@type': 'ItemList',
      name: 'Productos Mojo Pasión',
      itemListElement: PRODUCTS.map((product, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'Product',
          name: product.name,
          description: product.description,
          image: `${BASE}${productImages[i].src}`,
          brand: { '@type': 'Brand', name: 'Mojo Pasión' },
          offers: {
            '@type': 'Offer',
            price: (product.priceInCents / 100).toFixed(2),
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
            url: `${BASE}/tienda`,
          },
        },
      })),
    },
  ],
};
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preload fuentes críticas (latin) para evitar render blocking -->
    <link rel="preload" href={cormorantLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorantLatin400i} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={dmSansLatin300} as="font" type="font/woff2" crossorigin />

    <title>Mojo Pasión — Mojo rojo palmero artesano</title>
    <meta name="description" content="No es para todos. Es para ti. Mojo rojo palmero artesano con pimienta de Puntagorda, sal de Fuencaliente y receta de familia. Hecho a mano en Canarias." />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://www.mojopasion.com" />
<meta property="og:title" content="Mojo Pasión — No es para todos. Es para ti." />
<meta property="og:description" content="Mojo rojo palmero artesano con pimienta de Puntagorda, sal de Fuencaliente y receta de familia. Hecho a mano en Canarias." />
<meta property="og:image" content="https://www.mojopasion.com/images/hero.jpg" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Mojo Pasión — No es para todos. Es para ti." />
<meta name="twitter:description" content="Mojo rojo palmero artesano con pimienta de Puntagorda, sal de Fuencaliente y receta de familia. Hecho a mano en Canarias." />
<meta name="twitter:image" content="https://www.mojopasion.com/images/hero.jpg" />
    <!-- JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  </head>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
    });
  });
</script>
  <body>
  <header class="header" id="header">
      <img src="/images/logo-horizontal.png" alt="Mojo Pasión — logo mojo rojo palmero artesano canario" class="header-logo" width="200" height="50" />
      <div class="header-actions">
        <a href="/checkout" id="cart-toggle" class="header-cart-btn" aria-label="Ver carrito">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span id="cart-count" class="header-cart-count">0</span>
        </a>
        <a href="/tienda" class="header-cta">Comprar</a>
      </div>
    </header>
    <!-- HERO -->
      <section class="hero">
        <img src="/images/hero.avif" alt="Tarro de mojo rojo palmero artesano sobre madera — Mojo Pasión canario" class="hero-img" />
        <div class="hero-content">
          <h1 class="hero-small">Mojo rojo palmero artesano</h1>
          <p class="hero-title">No es para todos</p>
          <p class="hero-subtitle">Es para ti.</p>
<a href="/tienda" class="hero-cta">Comprar</a>
        </div>
      </section>

      <!-- PIMIENTA PALMERA -->
      <section class="ingrediente fade-in">
        <img src="/images/pimienta.avif" alt="Pimienta palmera de Puntagorda — ingrediente artesano del mojo rojo canario" class="ingrediente-img" style="object-position: center 65%;" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Pimienta palmera, punto.</h2>
              <p class="ingrediente-sub">Hay muchos mojos, este es auténtico mojo rojo palmero.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SAL DE FUENCALIENTE -->
      <section class="ingrediente">
        <img src="/images/sal.avif" alt="Sal marina de Fuencaliente — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Sal marina de Fuencaliente.</h2>
              <p class="ingrediente-sub">El ingrediente que nadie nombra su origen, y a nosotros nos enorgullece.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ACEITE DE OLIVA -->
      <section class="ingrediente">
        <img src="/images/aceite.avif" alt="Aceite de oliva virgen extra — base del mojo rojo palmero artesano canario" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Aceite de oliva, sin debate.</h2>
              <p class="ingrediente-sub">Acompañado con el toque justo de vinagre de vino.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- AJO DEL PAÍS -->
      <section class="ingrediente">
        <img src="/images/ajo.avif" alt="Ajo del país canario — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" style="object-position: center bottom;" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Ajo del país, el que sabe.</h2>
              <p class="ingrediente-sub">Pequeño, imperfecto, insustituible.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- COMINO -->
      <section class="ingrediente">
        <img src="/images/comino.avif" alt="Comino en grano — especia artesana del mojo rojo palmero canario" class="ingrediente-img" style="object-position: 20% center;" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Comino, el que no se ve pero se siente.</h2>
              <p class="ingrediente-sub">Discreto. Imprescindible. El grano que le da el toque.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- LAS MANOS -->
      <section class="ingrediente">
        <img src="/images/manos.avif" alt="Manos artesanas elaborando mojo rojo palmero canario — receta tradicional" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">El ingrediente estrella, el que no se puede comprar.</h2>
              <p class="ingrediente-sub">Las manos de quien lleva décadas haciendo el mojo rojo palmero. Mojo Pasión.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- PRODUCTOS -->
      <section class="productos fade-in" id="productos">
        <div class="productos-grid">
          {PRODUCTS.map((product) => (
            <ProductCard
              priceId={product.priceId}
              name={product.name}
              description={product.description}
              priceDisplay={product.priceDisplay}
              priceInCents={product.priceInCents}
              image={product.image}
              imageAlt={product.imageAlt}
            />
          ))}
        </div>
      </section>

      <!-- CTA PAPA -->
      <section class="cta-papa fade-in">
        <img src="/images/papa.avif" alt="Papa arrugada canaria con mojo rojo palmero artesano — Mojo Pasión" class="cta-papa-img" />
        <div class="cta-papa-content">
          <p class="hero-title">¿Tienes un <span style="color: var(--color-rojo);">negocio?</span></p>
          <p class="papa-subtitle">Formatos HORECA para llevar el mojo palmero artesano a tu carta.</p>
          <a href="mailto:hola@mojopasion.com" class="hero-cta">Escríbenos</a>
        </div>
      </section>

    </main>
	<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll < lastScroll && currentScroll > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
      lastScroll = currentScroll;
    });
  });
</script>

<!-- FOOTER -->
      <footer class="footer">
        <div class="footer-row">
          <img src="/images/logo-horizontal.png" alt="Mojo Pasión — mojo rojo palmero artesano canario" class="footer-logo" width="160" height="40" />
          <div class="footer-links">
            <a href="/aviso-legal" class="footer-link">Aviso legal</a>
            <a href="/privacidad" class="footer-link">Política de privacidad</a>
            <a href="https://instagram.com/mojo_pasion" target="_blank" class="footer-social-link">Instagram</a>
            <a href="https://tiktok.com/@mojopasion" target="_blank" class="footer-social-link">TikTok</a>
          </div>
          <p class="footer-copy">© 2026 Mojo Pasión. Todos los derechos reservados.</p>
        </div>
        <p class="footer-seo">Mojo Pasión — Mojo rojo palmero artesano elaborado en Canarias con pimienta palmera, sal marina de la isla y respetando la receta familiar.</p>
      </footer>
    <script>
      import '../lib/cart.ts';
    </script>
    <CookieConsent />
    <script is:inline>
      // Badge del carrito
      (function () {
        function updateBadge() {
          var badge = document.getElementById('cart-count');
          if (!badge) return;
          var n = window.Cart.count();
          badge.textContent = String(n);
          badge.style.display = n > 0 ? 'flex' : 'none';
        }
        document.addEventListener('DOMContentLoaded', updateBadge);
        window.addEventListener('cart:update', updateBadge);
      })();
    </script>
  </body>
</html>
<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 560px;
  }

  .hero-small {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(48px, 6.2vw, 86px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-rojo);
    line-height: 1.05;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    background: rgba(17, 17, 17, 0.85);
    border: 0.5px solid #444444;
    padding: 0.75rem 2rem;
    transition: border-color 0.3s ease;
  }

  .hero-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .ingrediente {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ingrediente-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ingrediente-content {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(17, 17, 17, 0.85);
    max-width: 560px;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .ingrediente-content:hover {
    transform: translateY(-50%) scale(1.02);
    background: rgba(17, 17, 17, 0.92);
  }

  .ingrediente-content.izquierda {
    left: 0;
  }

  .ingrediente-content.derecha {
    right: 0;
  }

  .ingrediente-texto {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    padding: 2rem 2rem;
  }

  .ingrediente-copy {
    flex: 1;
    padding: 0 1.5rem;
  }

  .ingrediente-barra {
    width: 3px;
    background: var(--color-rojo);
    flex-shrink: 0;
    align-self: stretch;
    min-height: 80px;
  }

  .ingrediente-title {
    font-family: var(--font-serif);
    font-size: clamp(38px, 3.2vw, 58px);
    font-weight: 400;
    font-style: italic;
    color: #F0EBE0;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ingrediente-sub {
    font-family: var(--font-sans);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    color: #AAAAAA;
    line-height: 1.7;
    letter-spacing: 1.2px;
  }

  .productos {
    background: #111111;
    padding: 6rem 2rem;
  }

  .productos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
    max-width: 1160px;
    margin: 0 auto;
  }

  .cta-papa {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .cta-papa-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 85% center;
  }

  .cta-papa-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 600px;
  }

  .papa-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 3rem;
    background: #111111;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .header.visible {
    opacity: 1;
    pointer-events: all;
  }

  .header-logo {
    height: 50px;
    width: auto;
  }

  .header-cta {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    border: 0.5px solid #444444;
    padding: 0.6rem 1.5rem;
    transition: border-color 0.3s ease;
  }

  .header-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .footer {
    background: #0a0a0a;
    padding: 1.5rem 3rem;
    border-top: 0.5px solid #222222;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    width: 100%;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .footer-logo {
    height: 32px;
    width: auto;
    opacity: 0.8;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #666666;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--color-crema);
  }

  .footer-social-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #666666;
    text-decoration: none;
  }

  .footer-social-link:hover {
    color: var(--color-rojo);
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 300;
    color: #444444;
    letter-spacing: 1px;
  }

  .footer-seo {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 300;
    color: #333333;
    letter-spacing: 0.5px;
    text-align: center;
    width: 100%;
    margin-top: 1rem;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {

    .hero-content {
      left: 5%;
      right: 5%;
      max-width: 90%;
      top: 5%;
      transform: none;
    }

    .hero-title {
      font-size: clamp(42px, 12vw, 64px);
    }

    .hero-subtitle {
      font-size: clamp(42px, 12vw, 64px);
    }

    .ingrediente-content {
      max-width: 90%;
    }

    .ingrediente-content.izquierda {
      left: 0;
    }

    .ingrediente-content.derecha {
      right: 0;
    }

    .ingrediente-title {
      font-size: clamp(28px, 8vw, 44px);
    }

    .ingrediente-sub {
      font-size: 12px;
    }

    .productos {
      padding: 4rem 1.25rem;
    }

    .productos-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .cta-papa-content {
      left: 5%;
      right: 5%;
      max-width: 90%;
      top: 5%;
      transform: none;
    }

    .papa-subtitle {
      font-size: clamp(20px, 5vw, 28px);
      margin-top: 1rem;
    }

    .header {
      padding: 0.6rem 1.5rem;
    }

    .footer-row {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      margin-right: 0;
    }

  }

  /* Carrito en el header de la landing */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header-cart-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-crema);
    padding: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .header-cart-btn:hover {
    color: var(--color-rojo);
  }

  .header-cart-count {
    position: absolute;
    top: -2px;
    right: -4px;
    background: var(--color-rojo);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    line-height: 1;
  }

</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll < lastScroll && currentScroll > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
      lastScroll = currentScroll;
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  });
</script>