---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mojo Pasión — Mojo rojo palmero artesano</title>
  </head>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
    });
  });
</script>
  <body>
  <header class="header" id="header">
      <img src="/images/logo-horizontal.png" alt="Mojo Pasión" class="header-logo" />
      <a href="#cta" class="header-cta">Comprar</a>
    </header>
    <!-- HERO -->
      <section class="hero">
        <img src="/images/hero.jpg" alt="Mojo Pasión" class="hero-img" />
        <div class="hero-content">
          <p class="hero-small">Mojo rojo palmero artesano</p>
          <h1 class="hero-title">El mojo que no se vende.</h1>
          <p class="hero-subtitle">Hasta ahora.</p>
        </div>
      </section>

      <!-- PIMIENTA PALMERA -->
      <section class="ingrediente">
        <img src="/images/pimienta.jpg" alt="Pimienta palmera de Puntagorda" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Pimienta palmera, o no hay mojo.</h2>
              <p class="ingrediente-sub">Cuando abuela hace el mojo en casa, sabe qué pimienta usar.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SAL DE FUENCALIENTE -->
      <section class="ingrediente">
        <img src="/images/sal.jpg" alt="Sal marina de Fuencaliente" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Sal marina de Fuencaliente.</h2>
              <p class="ingrediente-sub">El ingrediente que nadie nombra su origen, y a nosotros nos enorgullece.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ACEITE DE OLIVA -->
      <section class="ingrediente">
        <img src="/images/aceite.jpg" alt="Aceite de oliva" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Aceite de oliva, sin debate.</h2>
              <p class="ingrediente-sub">Acompañado con el toque justo de vinagre</p>
            </div>
          </div>
        </div>
      </section>

      <!-- AJO DEL PAÍS -->
      <section class="ingrediente">
        <img src="/images/ajo.jpg" alt="Ajo del país" class="ingrediente-img" style="object-position: center bottom;" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Ajo del país, el que sabe.</h2>
              <p class="ingrediente-sub">Pequeño, imperfecto, insustituible.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- COMINO -->
      <section class="ingrediente">
        <img src="/images/comino.jpg" alt="Comino" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Comino, el que no se ve pero se siente.</h2>
              <p class="ingrediente-sub">Discreto. Imprescindible. El que lo redondea todo.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- LAS MANOS -->
      <section class="ingrediente">
        <img src="/images/manos.jpg" alt="Las manos de quien lo hace" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">El ingrediente estrella, el que no se puede comprar.</h2>
              <p class="ingrediente-sub">Las manos de quien lleva décadas haciendo el mojo palmero. Mojo Pasión.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta">
        <div class="cta-content">
          <p class="cta-label">Mojo rojo palmero artesano</p>
          <h2 class="cta-title">La receta ya está.</h2>
          <p class="cta-subtitle">El mojo a la venta, casi.</p>
          <form class="cta-form">
            <input type="email" placeholder="Tu email" class="cta-input" />
            <button type="submit" class="cta-btn">Avísame</button>
          </form>
          <p class="cta-note">Sin spam. Solo mojo.</p>
        </div>

        <div class="cta-divider"></div>

        <div class="cta-content">
          <h2 class="cta-title-b">¿Quieres probarlo antes que nadie?</h2>
          <p class="cta-subtitle">El mojo que no se vende quiere decir muchas cosas. Si lo entiendes, eres de los nuestros.</p>
          <a href="mailto:hola@mojopasion.com" class="cta-btn-b">Escríbenos</a>
        </div>
      </section>

    </main>
	<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll < lastScroll && currentScroll > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
      lastScroll = currentScroll;
    });
  });
</script>
  </body>
</html>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 560px;
  }

  .hero-small {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-rojo);
    line-height: 1.05;
  }

  .ingrediente {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ingrediente-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ingrediente-content {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(17, 17, 17, 0.85);
    max-width: 560px;
  }

  .ingrediente-content.izquierda {
    left: 0;
  }

  .ingrediente-content.derecha {
    right: 0;
  }

  .ingrediente-texto {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    padding: 2rem 2rem;
  }

  .ingrediente-copy {
    flex: 1;
    padding: 0 1.5rem;
  }

  .ingrediente-barra {
    width: 3px;
    background: var(--color-rojo);
    flex-shrink: 0;
    align-self: stretch;
    min-height: 80px;
  }

  .ingrediente-title {
    font-family: var(--font-serif);
    font-size: clamp(38px, 3.2vw, 58px);
    font-weight: 400;
    font-style: italic;
    color: #F0EBE0;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ingrediente-sub {
    font-family: var(--font-sans);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    color: #AAAAAA;
    line-height: 1.7;
    letter-spacing: 1.2px;
  }

  .cta {
    background: #111111;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    padding: 6rem 2rem;
  }

  .cta-content {
    text-align: center;
    mmax-width: 700px;
  }

  .cta-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1.5rem;
  }

  .cta-title {
    font-family: var(--font-serif);
    font-size: clamp(42px, 5vw, 72px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .cta-title-b {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-crema);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 300;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.2;
    margin-bottom: 2.5rem;
  }

  .cta-form {
    display: flex;
    gap: 0;
    max-width: 420px;
    margin: 0 auto 1rem;
  }

  .cta-input {
    flex: 1;
    padding: 1rem 1.5rem;
    background: #2a2a2a;
    border: 0.5px solid #555555;
    border-right: none;
    color: var(--color-crema);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    outline: none;
  }

  .cta-input::placeholder {
    color: #555555;
  }

  .cta-btn {
    padding: 1rem 2rem;
    background: var(--color-rojo);
    border: none;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .cta-btn-b {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: transparent;
    border: 0.5px solid #444444;
    color: var(--color-crema);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
  }

  .cta-note {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    color: #777777;
    letter-spacing: 1px;
  }

  .cta-divider {
    width: 1px;
    height: 60px;
    background: #333333;
  }
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 3rem;
    background: #111111;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .header.visible {
    opacity: 1;
    pointer-events: all;
  }

  .header-logo {
    height: 50px;
    width: auto;
  }
  .header-cta {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    border: 0.5px solid #444444;
    padding: 0.6rem 1.5rem;
    transition: border-color 0.3s ease;
  }

  .header-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }
</style>