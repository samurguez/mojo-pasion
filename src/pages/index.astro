---
import '../styles/global.css';

import cormorantLatin400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-normal.woff2?url';
import cormorantLatin400i from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-400-italic.woff2?url';
import dmSansLatin300 from '@fontsource/dm-sans/files/dm-sans-latin-300-normal.woff2?url';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preload fuentes críticas (latin) para evitar render blocking -->
    <link rel="preload" href={cormorantLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorantLatin400i} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={dmSansLatin300} as="font" type="font/woff2" crossorigin />

    <title>Mojo Pasión — Mojo rojo palmero artesano</title>
    <meta name="description" content="El mojo que no se vende. Pimienta palmera de Puntagorda, sal de Fuencaliente, receta de familia. Hecho a mano en Canarias." />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://www.mojopasion.com" />
<meta property="og:title" content="Mojo Pasión — Mojo rojo palmero artesano" />
<meta property="og:description" content="El mojo que no se vende. Pimienta palmera de Puntagorda, sal de Fuencaliente, receta de familia. Hecho a mano en Canarias." />
<meta property="og:image" content="https://www.mojopasion.com/images/hero.jpg" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Mojo Pasión — Mojo rojo palmero artesano" />
<meta name="twitter:description" content="El mojo que no se vende. Pimienta palmera de Puntagorda, sal de Fuencaliente, receta de familia. Hecho a mano en Canarias." />
<meta name="twitter:image" content="https://www.mojopasion.com/images/hero.jpg" />
	<script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      window.mojoCookiesAccepted = false;

      function loadGA() {
        if (window.mojoCookiesAccepted) return;
        window.mojoCookiesAccepted = true;
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-4K3BK6E95M';
        s.async = true;
        document.head.appendChild(s);
        gtag('config', 'G-4K3BK6E95M');
      }
    </script>
  </head>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
    });
  });
</script>
  <body>
  <header class="header" id="header">
      <img src="/images/logo-horizontal.png" alt="Mojo Pasión — logo mojo rojo palmero artesano canario" class="header-logo" width="200" height="50" />
      <a href="#cta" class="header-cta">Comprar</a>
    </header>
    <!-- HERO -->
      <section class="hero">
        <img src="/images/hero.avif" alt="Tarro de mojo rojo palmero artesano sobre madera — Mojo Pasión canario" class="hero-img" />
        <div class="hero-content">
          <h1 class="hero-small">Mojo rojo palmero artesano</h1>
          <p class="hero-title">El mojo que no se vende.</p>
          <p class="hero-subtitle">Hasta ahora.</p>
<a href="#cta" class="hero-cta">Comprar</a>
        </div>
      </section>

      <!-- PIMIENTA PALMERA -->
      <section class="ingrediente fade-in">
        <img src="/images/pimienta.avif" alt="Pimienta palmera de Puntagorda — ingrediente artesano del mojo rojo canario" class="ingrediente-img" style="object-position: center 65%;" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Pimienta palmera, punto.</h2>
              <p class="ingrediente-sub">Hay muchos mojos, este es auténtico mojo rojo palmero.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SAL DE FUENCALIENTE -->
      <section class="ingrediente">
        <img src="/images/sal.avif" alt="Sal marina de Fuencaliente — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Sal marina de Fuencaliente.</h2>
              <p class="ingrediente-sub">El ingrediente que nadie nombra su origen, y a nosotros nos enorgullece.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ACEITE DE OLIVA -->
      <section class="ingrediente">
        <img src="/images/aceite.avif" alt="Aceite de oliva virgen extra — base del mojo rojo palmero artesano canario" class="ingrediente-img" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Aceite de oliva, sin debate.</h2>
              <p class="ingrediente-sub">Acompañado con el toque justo de vinagre de vino.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- AJO DEL PAÍS -->
      <section class="ingrediente">
        <img src="/images/ajo.avif" alt="Ajo del país canario — ingrediente artesano del mojo rojo palmero" class="ingrediente-img" style="object-position: center bottom;" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Ajo del país, el que sabe.</h2>
              <p class="ingrediente-sub">Pequeño, imperfecto, insustituible.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- COMINO -->
      <section class="ingrediente">
        <img src="/images/comino.avif" alt="Comino en grano — especia artesana del mojo rojo palmero canario" class="ingrediente-img" style="object-position: 20% center;" />
        <div class="ingrediente-content derecha">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">Comino, el que no se ve pero se siente.</h2>
              <p class="ingrediente-sub">Discreto. Imprescindible. El grano que le da el toque.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- LAS MANOS -->
      <section class="ingrediente">
        <img src="/images/manos.avif" alt="Manos artesanas elaborando mojo rojo palmero canario — receta tradicional" class="ingrediente-img" />
        <div class="ingrediente-content izquierda">
          <div class="ingrediente-texto">
            <div class="ingrediente-barra"></div>
            <div class="ingrediente-copy">
              <h2 class="ingrediente-title">El ingrediente estrella, el que no se puede comprar.</h2>
              <p class="ingrediente-sub">Las manos de quien lleva décadas haciendo el mojo rojo palmero. Mojo Pasión.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta fade-in" id="cta">
        <div class="cta-content">
          <p class="cta-label">Mojo rojo palmero artesano</p>
          <h2 class="cta-title">La receta ya está.</h2>
          <p class="cta-subtitle">El mojo a la venta, casi.</p>
          <form class="cta-form" id="waitlist-form">
  <input type="email" placeholder="Tu email" class="cta-input" id="waitlist-email" required />
  <button type="submit" class="cta-btn">Avísame</button>
</form>
<p class="cta-success" id="cta-success" style="display:none;"><span style="color: var(--color-rojo);">¡Hecho!</span> Te avisamos en cuanto el mojo esté a la venta.</p>
          <p class="cta-note">Sin spam. Solo mojo.</p>
        </div>
      </section>

      <!-- CTA PAPA -->
      <section class="cta-papa fade-in">
        <img src="/images/papa.avif" alt="Papa arrugada canaria con mojo rojo palmero artesano — Mojo Pasión" class="cta-papa-img" />
        <div class="cta-papa-content">
          <p class="hero-title">¿Quieres una muestra?</p>
          <p class="papa-subtitle">El mojo que <span style="color: var(--color-rojo);">no se vende</span> quiere decir muchas cosas. Si lo entiendes, <span style="color: var(--color-rojo);">eres de los nuestros.</span></p>
          <a href="mailto:hola@mojopasion.com" class="hero-cta">Escríbenos</a>
        </div>
      </section>

    </main>
	<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('header');
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll < lastScroll && currentScroll > 50) {
        header.classList.add('visible');
      } else {
        header.classList.remove('visible');
      }
      lastScroll = currentScroll;
    });
  });
</script>

<!-- FOOTER -->
      <footer class="footer">
        <div class="footer-row">
          <img src="/images/logo-horizontal.png" alt="Mojo Pasión — mojo rojo palmero artesano canario" class="footer-logo" width="160" height="40" />
          <div class="footer-links">
            <a href="/aviso-legal" class="footer-link">Aviso legal</a>
            <a href="/privacidad" class="footer-link">Política de privacidad</a>
            <a href="https://instagram.com/mojo_pasion" target="_blank" class="footer-social-link">Instagram</a>
            <a href="https://tiktok.com/@mojopasion" target="_blank" class="footer-social-link">TikTok</a>
          </div>
          <p class="footer-copy">© 2026 Mojo Pasión. Todos los derechos reservados.</p>
          <p class="footer-seo">Mojo Pasión — Mojo rojo palmero artesano elaborado en Canarias con pimienta palmera, sal marina de la isla y respetando la receta familiar.</p>
        </div>
      </footer>
<div class="cookies-banner" id="cookies-banner">
      <p class="cookies-text">Solo usamos cookies de análisis para mejorar nuestro servicio. Sin publicidad, sin terceros, sin trampa. </p>
      <div class="cookies-btns">
        <button class="cookies-accept" onclick="acceptCookies()">Aceptar</button>
        <button class="cookies-reject" onclick="rejectCookies()">Rechazar</button>
      </div>
    </div>

    <script is:inline>
      function acceptCookies() {
        localStorage.setItem('mojo-cookies', 'accepted');
        document.getElementById('cookies-banner').style.display = 'none';
        loadGA();
      }

      function rejectCookies() {
        localStorage.setItem('mojo-cookies', 'rejected');
        document.getElementById('cookies-banner').style.display = 'none';
      }

      if (localStorage.getItem('mojo-cookies') === 'accepted') {
        loadGA();
        document.getElementById('cookies-banner').style.display = 'none';
      } else if (localStorage.getItem('mojo-cookies') === 'rejected') {
        document.getElementById('cookies-banner').style.display = 'none';
      }
    </script>
  </body>
</html>
<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 560px;
  }

  .hero-small {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-rojo);
    line-height: 1.05;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    background: rgba(17, 17, 17, 0.85);
    border: 0.5px solid #444444;
    padding: 0.75rem 2rem;
    transition: border-color 0.3s ease;
  }

  .hero-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .ingrediente {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ingrediente-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ingrediente-content {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(17, 17, 17, 0.85);
    max-width: 560px;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .ingrediente-content:hover {
    transform: translateY(-50%) scale(1.02);
    background: rgba(17, 17, 17, 0.92);
  }

  .ingrediente-content.izquierda {
    left: 0;
  }

  .ingrediente-content.derecha {
    right: 0;
  }

  .ingrediente-texto {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    padding: 2rem 2rem;
  }

  .ingrediente-copy {
    flex: 1;
    padding: 0 1.5rem;
  }

  .ingrediente-barra {
    width: 3px;
    background: var(--color-rojo);
    flex-shrink: 0;
    align-self: stretch;
    min-height: 80px;
  }

  .ingrediente-title {
    font-family: var(--font-serif);
    font-size: clamp(38px, 3.2vw, 58px);
    font-weight: 400;
    font-style: italic;
    color: #F0EBE0;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ingrediente-sub {
    font-family: var(--font-sans);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    color: #AAAAAA;
    line-height: 1.7;
    letter-spacing: 1.2px;
  }

  .cta {
    background: #111111;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 0;
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    padding: 6rem 2rem;
    margin: 0 auto;
  }

  .cta-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gris);
    margin-bottom: 1.5rem;
  }

  .cta-title {
    font-family: var(--font-serif);
    font-size: clamp(42px, 5vw, 72px);
    font-weight: 400;
    color: var(--color-crema);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .cta-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 300;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.2;
    margin-bottom: 2.5rem;
  }

  .cta-form {
    display: flex;
    gap: 0;
    max-width: 420px;
    margin: 0 auto 1rem;
  }

  .cta-input {
    flex: 1;
    padding: 1rem 1.5rem;
    background: #2a2a2a;
    border: 0.5px solid #555555;
    border-right: none;
    color: var(--color-crema);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    outline: none;
  }

  .cta-input::placeholder {
    color: #555555;
  }

  .cta-btn {
    padding: 1rem 2rem;
    background: var(--color-rojo);
    border: none;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .cta-btn-b {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: transparent;
    border: 0.5px solid #444444;
    color: var(--color-crema);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
  }

  .cta-note {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    color: #777777;
    letter-spacing: 1px;
    margin-top: 1rem;
  }

 .cta-success {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 300;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.2;
    margin-top: 1rem;
  }

  .cta-papa {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .cta-papa-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 85% center;
  }

  .cta-papa-content {
    position: absolute;
    top: 50%;
    left: 6%;
    transform: translateY(-50%);
    max-width: 600px;
  }

  .papa-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 400;
    font-style: italic;
    color: var(--color-gris);
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  .cta-divider {
    width: 1px;
    height: 60px;
    background: #333333;
  }

  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 3rem;
    background: #111111;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .header.visible {
    opacity: 1;
    pointer-events: all;
  }

  .header-logo {
    height: 50px;
    width: auto;
  }

  .header-cta {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    border: 0.5px solid #444444;
    padding: 0.6rem 1.5rem;
    transition: border-color 0.3s ease;
  }

  .header-cta:hover {
    border-color: var(--color-rojo);
    color: var(--color-rojo);
  }

  .footer {
    background: #0a0a0a;
    padding: 1.5rem 3rem;
    border-top: 0.5px solid #222222;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .footer-logo {
    height: 32px;
    width: auto;
    opacity: 0.8;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #666666;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--color-crema);
  }

  .footer-social-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #666666;
    text-decoration: none;
  }

  .footer-social-link:hover {
    color: var(--color-rojo);
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 300;
    color: #444444;
    letter-spacing: 1px;
  }

  .footer-seo {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 300;
    color: #333333;
    letter-spacing: 0.5px;
    text-align: center;
    margin-top: 0.5rem;
  }

  .cookies-banner {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    border: 0.5px solid #333333;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    z-index: 200;
    max-width: 760px;
    width: 95%;
  }

  .cookies-text {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    color: #BBBBBB;
    margin: 0;
  }

  .cookies-btns {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookies-accept {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: var(--color-rojo);
    color: #ffffff;
    border: none;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
  }

  .cookies-reject {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: transparent;
    color: #666666;
    border: 0.5px solid #444444;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {

    .cookies-banner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.5rem;
    }

    .cookies-btns {
      width: 100%;
    }

    .cookies-accept,
    .cookies-reject {
      flex: 1;
      text-align: center;
    }

    .hero-content {
      left: 5%;
      right: 5%;
